{
    "name": "perfect-english/backend",
    "description": "PHP dependencies for the Perfect English API.",
    "type": "project",
    "require": {
        "phpmailer/phpmailer": "^6.9",
        "ramsey/uuid": "^4.9",
        "stripe/stripe-php": "^15.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.1.0"
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/" 
        },
        "files": [
            "api/config.php"
        ]
    }

}
