Options -MultiViews
Options -Indexes

# ── SPA Fallback — redirect all non-file/dir requests to index.html ──
# Required for React Router (BrowserRouter) to handle /help, /reset-password, etc.
RewriteEngine On
RewriteBase /

# Allow /api/ requests to pass through to the PHP backend unchanged
RewriteCond %{REQUEST_URI} ^/api/ [NC]
RewriteRule ^ - [L]

# Allow real files and directories (JS, CSS, assets, etc.) to pass through
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Everything else → React app entry point
RewriteRule ^ index.html [QSA,L]

# ── Security headers ──
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always unset X-Powered-By
</IfModule>

# ── Cache static assets ──
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html                 "access plus 0 seconds"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
</IfModule>
