{
  "id": "wf_cnv_exome_full_v3",
  "name": "CNV Exome Full Pipeline v3 — SeqNode Enhanced",
  "description": "Pipeline WES completo para análise de CNV e SNV germinal, superando o scriptGui.py em todas as fases. Inclui: QC → Alinhamento → MarkDup (marcação, não remoção) → Cobertura → CNVkit (HMM-Germline) → ExomeDepth (leave-one-out + RDS cache) → Consenso Dual-Caller (TSV + split por caller) → AnnotSV → Filtro SegDup/PAR → NOVO: GATK HaplotypeCaller → BCFtools filter → SnpEff+SnpSift (SNV). Desenhado para exoma Illumina PE com referência hg38.",
  "version": "3.0.0",
  "author": "SeqNode-OS",
  "changelog": [
    "v3.0.0 — Segmentação CNVkit trocada para hmm-germline (melhor sensibilidade em germinal WES)",
    "v3.0.0 — Sambamba MarkDup: remove_duplicates=false; reads marcados são excluídos por GATK automaticamente mas preservados para re-análise",
    "v3.0.0 — ExomeDepth: leave-one-out activado, RDS cache, min_num_exons=2, sex_chr_mode=auto",
    "v3.0.0 — CNV Consensus: formato TSV enriquecido, split por caller, scores de confiança",
    "v3.0.0 — Mosdepth: thresholds clínicos 10/20/30/50×, no_per_base para eficiência em WES",
    "v3.0.0 — NOVA FASE 11: GATK HaplotypeCaller (SNVs + indels germinais, modo GVCF disponível)",
    "v3.0.0 — NOVA FASE 12: BCFtools norm + filter (VCF limpo, normalizado, indexado)",
    "v3.0.0 — NOVA FASE 13: SnpEff + SnpSift (anotação funcional HGVS + ClinVar + dbSNP)",
    "v3.0.0 — AnnotSV: rankingScoreThreshold activado via YAML corrigido"
  ],
